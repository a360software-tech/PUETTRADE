# App
APP_NAME=Trading Platform
DEBUG=true
ENVIRONMENT=local
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/trading_platform
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_AUTO_CREATE_SCHEMA=false

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# IG Trading API
IG_API_KEY=your-ig-api-key
IG_ENVIRONMENT=demo
ALLOW_LIVE_TRADING=false
IG_API_URL=https://demo-api.ig.com/gateway/deal
IG_LIGHTSTREAMER_URL=https://demo-apd.marketdatasystems.com
IG_TIMEOUT_SECONDS=15
EXECUTION_MODE=paper
DEFAULT_WATCHLIST_EPICS=["CS.D.EURUSD.CFD.IP","CS.D.GBPUSD.CFD.IP","CS.D.USDJPY.CFD.IP","CS.D.AUDUSD.CFD.IP","CS.D.NZDUSD.CFD.IP","CS.D.USDCAD.CFD.IP","CS.D.EURJPY.CFD.IP","CS.D.GBPJPY.CFD.IP","CS.D.EURGBP.CFD.IP","CS.D.USDCHF.CFD.IP"]
